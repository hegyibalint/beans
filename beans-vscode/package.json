{
  "name": "beans-lsp",
  "displayName": "Beans LSP",
  "description": "Multi-language LSP for JVM languages",
  "version": "0.0.1",
  "publisher": "beans",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:java"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Beans LSP",
      "properties": {
        "beans.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the beans-lsp binary. Leave empty to use beans-lsp from PATH."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.82.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
